{
  "name": "s2j-cozy-brew",
  "version": "1.0.0",
  "description": "Using SwiftUI, reimplement the AppKit-based \"Cakebrew\".",
  "type": "module",
  "author": "Koutarou ISHIKAWA",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stein2nd/s2j-cozy-brew.git"
  },
  "homepage": "https://github.com/stein2nd/s2j-cozy-brew#readme",
  "bugs": {
    "url": "https://github.com/stein2nd/s2j-cozy-brew/issues"
  },
  "keywords": [],
  "directories": {
    "doc": "docs"
  },
  "files": [
    "README.md",
    "COMMON_SPEC.md",
    "LICENSE"
  ],
  "scripts": {
    "lint:docs": "s2j-docs-linter ./README.md ./docs/**/*.md",
    "swift:update": "swift package update",
    "swift:resolve": "swift package resolve",
    "swift:show-deps": "swift package show-dependencies",
    "test:local": "./scripts/test-local.sh",
    "test:local:macOS": "./scripts/test-local_macOS.sh",
    "test:local:iOSfull": "./scripts/test-local.sh --ios-device \"iPad Pro\" --ios-version \"15.0\" --enable-xcode-project --xcodegen-auto-install"
  },
  "devDependencies": {
    "@s2j/docs-linter": "^1.0.11"
  }
}
